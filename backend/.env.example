# ─────────────────────────────────────────────────────────────
# LLM provider selection: "gemini" | "anthropic" | "bedrock"
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini

# --- Google Gemini (used when LLM_PROVIDER=gemini) ---
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- Anthropic (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-8

# --- AWS Bedrock (used when LLM_PROVIDER=bedrock) ---
# Credentials via the standard AWS chain (env, profile, or role).
# BEDROCK_MODEL=anthropic.claude-opus-4-8-v1:0
# AWS_REGION=us-east-1

# ─────────────────────────────────────────────────────────────
# Publishing targets. Leave blank => local stub mode (writes to
# .local-mirror/ and logs). Fill in later for real pushes.
# NOTE: do not put inline comments after a value on the same line.
# ─────────────────────────────────────────────────────────────

# GitHub — e.g. GITHUB_REPO=my-org/cloud-adrs
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main

# Confluence — e.g. CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_BASE_URL=
CONFLUENCE_USER=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=

# Where generated ADRs are written (relative to the backend/ dir)
ADR_OUTPUT_DIR=../adrs
